{
  "name": "bdd-playwright-project",
  "version": "1.0.0",
  "description": "Cucumber + Playwright BDD suite generated by test-bdd skill",
  "scripts": {
    "dev": "cucumber-js --config cucumber.js -f summary",
    "test": "cucumber-js --config cucumber.js -f progress-bar",
    "test:headed": "cucumber-js --config cucumber.js --world-parameters '{\"headless\":false}'",
    "report": "node scripts/generate-report.js",
    "test:report": "cucumber-js --config cucumber.js && sleep 1 && node scripts/generate-report.js",
    "postinstall": "npx playwright install"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@cucumber/messages": "^34.0.1",
    "@playwright/test": "^1.40.0",
    "allure-cucumberjs": "^3.10.2",
    "playwright": "^1.40.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
